# Caddy reverse proxy for route-cast.
#
# Terminates HTTPS (auto Let's Encrypt cert for a real domain) and routes:
#   /api/*  -> backend:4000   (Express mounts its router at /api)
#   /*      -> frontend:3000  (Next.js)
#
# DOMAIN is read from the environment (set it in .env). Examples:
#   DOMAIN=routecast.example.com   -> real domain, automatic HTTPS
#   DOMAIN=:80                     -> HTTP only, for a bare-IP demo (no cert)

{$DOMAIN} {
	handle /api/* {
		reverse_proxy backend:4000
	}
	handle {
		reverse_proxy frontend:3000
	}
}
