# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=vrp
POSTGRES_PASSWORD=vrp_password
POSTGRES_DB=vrp
POSTGRES_PORT=5432
# Connection string used by the backend (host = service name inside compose)
DATABASE_URL=postgresql://vrp:vrp_password@postgres:5432/vrp

# ── Backend ───────────────────────────────────────────────────────────────
BACKEND_PORT=4000
# Internal URL of the Python optimization service
OPTIMIZATION_SERVICE_URL=http://optimization-service:8000
# OpenRouteService API key (optional). Get a free key at https://openrouteservice.org
# If left blank, the backend falls back to a Haversine distance/time matrix so
# the platform works fully offline / without an external API.
ORS_API_KEY=
# ORS routing profile. Use driving-hgv so routes respect heavy-goods-vehicle
# (truck) road restrictions; driving-car ignores them.
ORS_PROFILE=driving-hgv
# Address-search relevance: ISO country to restrict results to when no hub is
# selected, and the search radius (km) around a selected hub.
ORS_GEOCODE_COUNTRY=IN
ORS_GEOCODE_RADIUS_KM=60

# ── Optimization service ──────────────────────────────────────────────────
OPTIMIZATION_PORT=8000
# Per-vehicle solver time limit (seconds)
SOLVER_TIME_LIMIT=10

# ── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
# Public URL the browser uses to reach the backend (host machine, not compose net)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
